# ─────────────────────────────────────────────────────────────────────────────
# Auth (single-user gate)
# Generate AUTH_SECRET with: node -e "require('crypto').randomBytes(32).toString('hex')|console.log"
# ─────────────────────────────────────────────────────────────────────────────
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# AI Model
# Get your key at: https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Database (Supabase)
# Create a project at: https://supabase.com and copy from Project Settings > API
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth (Calendar, Gmail, Sheets)
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Slack OAuth
# Create an app at: https://api.slack.com/apps
# ─────────────────────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# HubSpot OAuth
# Create an app at: https://developers.hubspot.com
# ─────────────────────────────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Notion OAuth
# Create a public integration at: https://www.notion.so/my-integrations
# ─────────────────────────────────────────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# App URL
# Use http://localhost:3000 for local development
# Use your production domain when deploying (e.g. https://yourapp.vercel.app)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
